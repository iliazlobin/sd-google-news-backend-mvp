# verify/manifest.env — canonical contract for the host e2e loop and CI
# Source this: `set -a && source verify/manifest.env && set +a`
# DO NOT commit secrets here.

MODE=docker

# Port the app exposes on the host (in-container is always 8000)
PORT=${APP_PORT:-8010}

# Bring the stack up
UP=docker compose up --build -d

# Health check — must return 200
READY=curl -s -o /dev/null -w '%{http_code}' http://localhost:${APP_PORT:-8010}/healthz

# Accept both "200" and "200 OK" as valid READY responses
# Usage: RESULT=$(eval $READY); [ "$RESULT" = "200" ] && echo "healthy" || echo "down"

# Black-box acceptance suite
ACCEPTANCE=pytest verify/acceptance/ -v

# Tear down (including volumes)
DOWN=docker compose down -v

# Test dependencies for the acceptance suite
TEST_DEPS=httpx
