# .env — application configuration (copy from .env.example)
# cp .env.example .env && edit as needed

# PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://google_news:google_news@db:5432/google_news

# Redis connection string
REDIS_URL=redis://redis:6379/0

# Secret key for cryptographic operations (reserved for future auth — not yet used by the MVP)
SECRET_KEY=change-me-to-a-random-secret

# Host port for the app service (in-container is always 8000)
APP_PORT=8010

# FastAPI host binding (0.0.0.0 to accept external connections)
HOST=0.0.0.0

# Log level (debug | info | warning | error)
LOG_LEVEL=info
