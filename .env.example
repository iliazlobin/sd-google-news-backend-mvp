# Google News MVP — environment variables
# Copy this to .env and adjust as needed.
# The .env file is gitignored — never commit real secrets.

# PostgreSQL connection (async)
DATABASE_URL=postgresql+asyncpg://google_news:google_news@localhost:5432/google_news

# Redis connection
REDIS_URL=redis://localhost:6379/0

# Server
HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info
